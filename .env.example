# ─── Harusi Planners — Environment Variables ───────────────────────────────
# Copy this file to .env for local development.
# Production values must be set in Vercel dashboard:
#   Project → Settings → Environment Variables

# WhatsApp Business number (no + prefix, no spaces)
VITE_WHATSAPP_NUMBER=254799644100

# ─── Mailchimp (required for newsletter + quiz email capture) ──────────────
# API Key: mailchimp.com → Account → Extras → API Keys → Create A Key
MAILCHIMP_API_KEY=your_api_key_here

# Audience/List ID: Audience → Settings → Audience name & defaults → Audience ID
MAILCHIMP_LIST_ID=your_list_id_here

# Server prefix: the part before .api.mailchimp.com in your API key (e.g. us21)
MAILCHIMP_SERVER_PREFIX=us21
